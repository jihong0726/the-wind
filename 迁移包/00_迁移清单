## 🔧 附录：AI 指纹验证脚本（固化版）

`04_工具/ai_fingerprint_check.py` 没找到，下面是每章用的等价脚本，可直接存为文件调用：

```python
#!/usr/bin/env python3
"""AI 指纹与字数机械验证"""
import re, sys
from pathlib import Path

def check(md_path):
    text = Path(md_path).read_text(encoding='utf-8')
    body = text.split('**写作备注**')[0]

    hanzi = len(re.findall(r'[\u4e00-\u9fff]', body))

    patterns = {
        'T1-DASH':       (r'——[^\n]{1,8}。', 2),
        'T1-LONG-DASH':  (r'——[^\n]{25,}', 2),
        'T1-NEG-EQ':     (r'不是[^\n，。]{1,20}，是[^\n。]{1,20}', 2),
        'T1-NEG-DASH':   (r'不是[^\n。]{1,20}——', 2),
        'T1-KIND-OF':    (r'的那种', 2),
        'T1-LIKE':       (r'像是[^\n。]|像一[^\n。]', 2),
        'T1-THERE-IS':   (r'有一种[^\n。]{1,15}的', 2),
        'T2-THIS-IS':    (r'这是[^\n。]{1,30}最[^\n。]{1,15}的一[次回个]', 2),
        'T2-STATE':      (r'[^\n]{1,10}的状态', 2),
    }

    total, detail = 0, {}
    for name, (pat, lim) in patterns.items():
        m = re.findall(pat, body)
        if m:
            detail[name] = (len(m), m[:3])
            total += len(m)

    rate = total / hanzi * 1000 if hanzi else 0

    banned = ['呵','冷笑','勾起嘴角','不由得','不禁','他感到','她感到','心中一动','脑海中']
    places = ['首尔','韩国','釜山','台北','台南','台湾','吉隆坡','马来西亚']
    bh = {w: body.count(w) for w in banned if body.count(w) > 0}
    ph = {w: body.count(w) for w in places if body.count(w) > 0}

    print(f"汉字数: {hanzi}")
    print(f"AI 指纹: {total} / {rate:.2f}‰")
    for k, (n, ex) in detail.items():
        print(f"  {k}: {n} 处 {ex}")
    print(f"字数: {'🟢' if hanzi >= 3000 else '🔴'} {hanzi}/3000")
    print(f"指纹: {'🟢' if rate <= 5 else ('🟡' if rate <= 10 else '🔴')} {rate:.2f}‰")
    print(f"禁用词: {bh or '无'}")
    print(f"真实地名: {ph or '无'}")

if __name__ == '__main__':
    check(sys.argv[1])
```

保存为 `04_工具/ai_fingerprint_check.py`，`chmod +x` 即可。

